# Local agent/editor state — committed rules + settings are tracked; ignore local-only state.
.claude/settings.local.json
.claude/ai-core/

# NOTE: unlike python-template, data/ is NOT ignored — the frozen snapshot staged by the
# controller's fetch_data step ships with the published strategy repo so the backtest is
# reproducible. Generated verdicts/plots still go in output/.
output/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# C extensions
*.so

